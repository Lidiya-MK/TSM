<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mentor Login | Thrive Club</title>
  <link href="/css/output.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <style>
    .font-display { font-family: 'Playfair Display', serif; }
    .font-body { font-family: 'Montserrat', sans-serif; }
  </style>
</head>
<body class="bg-black text-white font-body min-h-screen flex flex-col items-center justify-center relative px-4 py-12">

  <!-- Back Arrow -->
  <a href="/landing" class="absolute top-6 left-6 flex items-center text-[#873ac2] hover:text-[#a978dd] transition">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-7 h-7 mr-1">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
    <span>Back</span>
  </a>

  <!-- Login Card -->
  <div class="bg-black border border-[#873ac2] rounded-2xl shadow-lg p-10 w-full max-w-md mt-10">
    <h1 class="text-3xl font-display text-center text-[#873ac2] mb-8">Mentor Login</h1>

    <form class="space-y-5">
      <div>
        <label class="block mb-2 text-sm font-semibold text-white/80">Email</label>
        <input type="email" placeholder="Enter your email" class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-[#873ac2]" required>
      </div>

      <div>
        <label class="block mb-2 text-sm font-semibold text-white/80">Password</label>
        <input type="password" placeholder="Enter your password" class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-[#873ac2]" required>
      </div>

      <button type="submit" class="w-full mt-4 bg-[#873ac2] hover:bg-[#a978dd] text-white font-semibold py-2 rounded-lg transition">
        Login
      </button>
    </form>

    <p class="mt-6 text-center text-white/70">
      Are you a trainee?  
      <a href="/trainee-login" class="text-[#873ac2] hover:text-[#a978dd] font-semibold transition">Login as a Trainee</a>
    </p>

    <p class="mt-3 text-center text-white/70">
      Don’t have an account?  
      <a href="/mentor-signup" class="text-[#873ac2] hover:text-[#a978dd] font-semibold transition">Sign up</a>
    </p>
  </div>
<script src="/js/mentorLogin.js"></script>
</body>
</html>
