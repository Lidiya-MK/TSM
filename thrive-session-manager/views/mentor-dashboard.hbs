<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mentor Dashboard | Thrive Club</title>
  <link href="/css/output.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
  <style>
    .font-display { font-family: 'Playfair Display', serif; }
    .font-body { font-family: 'Montserrat', sans-serif; }
    .modal { display: none; }
    .modal.active { display: flex; }
  </style>
</head>
<body class="bg-black text-white font-body min-h-screen">

<!-- Header -->
<header class="flex justify-between items-center px-8 py-5 border-b border-[#873ac2]/50">
  <div class="flex items-center space-x-3">
    <img src="/images/logo_mentor.png" alt="Thrive Club Logo" class="h-10 w-10 object-contain">
    <h1 class="text-2xl font-display text-[#873ac2]">Thrive Mentor</h1>
  </div>

  <div class="flex items-center space-x-4">
    <!-- Profile Section -->
    <div class="flex flex-col items-center">
      <div class="w-10 h-10 rounded-full border-2 border-[#873ac2] overflow-hidden mb-1">
        <img id="mentor-profile-pic" src="/images/placeholder.png" alt="Profile Picture" class="w-full h-full object-cover">
      </div>
      <p id="mentor-name" class="text-sm text-white/80 font-semibold">Name</p>
    </div>

    <!-- Logout Button -->
    <button id="logout-btn" class="px-4 py-2 bg-[#873ac2]/20 text-[#873ac2] border border-[#873ac2]/60 rounded-lg hover:bg-[#873ac2]/30 transition font-semibold">
      Logout
    </button>
  </div>
</header>



  <!-- Main Section -->
 <main class="p-8">
  <div class="flex justify-between items-center mb-8">
    <h2 class="text-3xl font-display text-[#ffffff]">Sessions</h2>
    <button onclick="openCreateModal()" class="px-5 py-2 bg-[#873ac2] hover:bg-[#a978dd] text-white rounded-lg font-semibold transition">
      + Create Session
    </button>
  </div>

  <div id="sessionsContainer" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
    {{!-- This will be dynamically populated via JS --}}
  </div>

  <p id="noSessionsMessage" class="text-white/60 text-lg mt-4 hidden">
    No sessions found. Create a new session to get started!
  </p>
</main>

<!-- Edit Modal -->
<div id="editModal" class="modal fixed inset-0 bg-black/70 justify-center items-center z-50 hidden">
  <div class="bg-black border border-[#873ac2] rounded-2xl p-8 w-full max-w-lg">
    <h2 class="text-2xl font-display text-[#873ac2] mb-4">Edit Session</h2>
    <form id="editSessionForm" class="space-y-5" enctype="multipart/form-data">
      <input type="hidden" name="sessionId" id="editSessionId">

      <div>
        <label class="block text-sm text-white/80 mb-1">Session Name</label>
        <input type="text" name="name" id="editName" class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-[#873ac2]" required>
      </div>

      <div>
        <label class="block text-sm text-white/80 mb-1">Description</label>
        <textarea name="description" id="editDescription" rows="3" class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-[#873ac2]" required></textarea>
      </div>

      <div>
        <label class="block text-sm text-white/80 mb-1">Cover Image</label>
        <input type="file" name="coverImage" id="editCoverImage" accept="image/*" class="w-full text-sm text-gray-400 bg-black border border-[#873ac2]/60 rounded-lg px-3 py-2 cursor-pointer focus:outline-none file:bg-[#873ac2] file:text-white file:border-none file:rounded-lg file:px-3 file:py-1.5 hover:file:bg-[#a978dd] transition">
      </div>

      <div>
        <label class="block text-sm text-white/80 mb-1">Date</label>
        <input type="date" name="date" id="editDate" class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-[#873ac2]" required>
      </div>

      <div>
        <label class="block text-sm text-white/80 mb-1">Instructor</label>
        <input type="text" name="instructorName" id="editInstructor" class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-[#873ac2]" required>
      </div>

      <div class="flex justify-end space-x-3">
        <button type="button" onclick="closeEditModal()" class="px-4 py-2 border border-gray-600 rounded hover:bg-gray-800 transition">Cancel</button>
        <button type="submit" class="px-4 py-2 bg-[#873ac2] hover:bg-[#a978dd] text-white rounded transition">Save</button>
      </div>
    </form>
  </div>
</div>

  <!-- Create Modal -->
<div id="createModal" class="modal fixed inset-0 bg-black/70 justify-center items-center z-50">
  <div class="bg-black border border-[#873ac2] rounded-2xl p-8 w-full max-w-lg">
    <h2 class="text-2xl font-display text-[#873ac2] mb-4">Create New Session</h2>
    <form class="space-y-5">
      <div>
        <label class="block text-sm text-white/80 mb-1">Session Name</label>
        <input 
          type="text" 
          name="name" 
          placeholder="Enter session name" 
          class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-[#873ac2]"
          required
        >
      </div>
      <div>
        <label class="block text-sm text-white/80 mb-1">Description</label>
        <textarea 
          name="description" 
          rows="3" 
          placeholder="Enter session description" 
          class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-[#873ac2]"
          required
        ></textarea>
      </div>
      <div>
        <label class="block text-sm text-white/80 mb-1">Image</label>
        <input 
          type="file" 
          name="coverImage"
          accept="image/*" 
          class="w-full text-sm text-gray-400 bg-black border border-[#873ac2]/60 rounded-lg px-3 py-2 cursor-pointer focus:outline-none file:bg-[#873ac2] file:text-white file:border-none file:rounded-lg file:px-3 file:py-1.5 hover:file:bg-[#a978dd] transition"
        >
      </div>
      <div>
        <label class="block text-sm text-white/80 mb-1">Date</label>
        <input 
          type="date" 
          name="date"
          class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-[#873ac2]"
          required
        >
      </div>
      <div>
        <label class="block text-sm text-white/80 mb-1">Instructor</label>
        <input 
          type="text" 
          name="instructor"
          placeholder="Enter instructor name" 
          class="w-full bg-black border border-[#873ac2]/60 rounded-lg px-4 py-2 text-white focus:outline-none focus:ring-2 focus:ring-[#873ac2]"
          required
        >
      </div>
      <div class="flex justify-end space-x-3">
        <button 
          type="button" 
          onclick="closeCreateModal()" 
          class="px-4 py-2 border border-gray-600 rounded hover:bg-gray-800 transition"
        >Cancel</button>
        <button 
          type="submit" 
          class="px-4 py-2 bg-[#873ac2] hover:bg-[#a978dd] text-white rounded transition"
        >Create</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/getMentor.js"></script>
<script src="/js/createSession.js"></script>
<script src="/js/getSessions.js"></script>
<script src="/js/deleteSession.js"></script>
<script src="/js/updateSession.js"></script>
  <script>
    const editModal = document.getElementById("editModal");
    const createModal = document.getElementById("createModal");

    function openEditModal() { editModal.classList.add("active"); }
    function closeEditModal() { editModal.classList.remove("active"); }

    function openCreateModal() { createModal.classList.add("active"); }
    function closeCreateModal() { createModal.classList.remove("active"); }
  </script>

</body>
</html>
